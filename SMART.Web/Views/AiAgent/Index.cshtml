@{
    ViewBag.Title = "AI Agent";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .ai-page {
        padding: 15px;
    }

    .ai-shell {
        display: flex;
        height: calc(100vh - 180px);
        min-height: 560px;
        border: 1px solid #ddd;
        background: #fff;
    }

    .ai-sidebar {
        width: 280px;
        background: #f7f7f7;
        border-right: 1px solid #ddd;
        padding: 12px;
        overflow-y: auto;
    }

    .ai-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 15px;
    }

    .chat-item {
        padding: 10px;
        margin-bottom: 7px;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
    }

        .chat-item:hover, .chat-item.active {
            background: #e8f1ff;
            border-color: #9cc7ff;
        }

    #chatBox {
        flex: 1;
        overflow-y: auto;
        background: #fafafa;
        border: 1px solid #ddd;
        padding: 18px;
        margin-bottom: 12px;
    }

    .msg-row {
        display: flex;
        margin-bottom: 12px;
    }

        .msg-row.user {
            justify-content: flex-end;
        }

        .msg-row.ai {
            justify-content: flex-start;
        }

    .msg-bubble {
        max-width: 75%;
        padding: 10px 13px;
        border-radius: 12px;
        line-height: 1.5;
        word-break: break-word;
    }

    .user .msg-bubble {
        background: #007bff;
        color: #fff;
        border-bottom-right-radius: 3px;
    }

    .ai .msg-bubble {
        background: #fff;
        border: 1px solid #ddd;
        color: #333;
        border-bottom-left-radius: 3px;
    }

    .ai-input-area {
        display: flex;
        gap: 8px;
        align-items: flex-end;
    }

    #txtMessage {
        resize: none;
    }

    .loading-text {
        font-style: italic;
        color: #777;
    }

    @@media(max-width: 768px) {
        .ai-shell {
            flex-direction: column;
            height: auto;
        }

        .ai-sidebar {
            width: 100%;
            height: 180px;
            border-right: none;
            border-bottom: 1px solid #ddd;
        }

        .msg-bubble {
            max-width: 95%;
        }
    }
</style>

<div class="ai-page">
    <h3>Smart ERP AI Agent</h3>

    <div class="ai-shell">
        <div class="ai-sidebar">
            <button id="btnNewChat" type="button" class="btn btn-success btn-block">
                + New Chat
            </button>

            <hr />

            <strong>Previous Chats</strong>
            <div id="chatList" style="margin-top:10px;"></div>
        </div>

        <div class="ai-main">
            <div style="margin-bottom:10px;">
                <select id="aiMode" class="form-control" style="width:230px;display:inline-block;">
                    <option value="General">General AI Chat</option>
                    <option value="ERP">ERP AI Assistant</option>
                </select>
            </div>

            <div id="chatBox">
                <div class="msg-row ai">
                    <div class="msg-bubble">
                        Hello! I am your Smart ERP AI Agent. How can I help you?
                    </div>
                </div>
            </div>

            <div class="ai-input-area">
                <textarea id="txtMessage" class="form-control" rows="2" placeholder="Ask anything..."></textarea>
                <button id="btnSend" type="button" class="btn btn-primary">
                    Send
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    var currentSessionId = 0;

    $(document).ready(function () {
        loadChatList();

        $("#btnNewChat").click(function () {
            createNewChat();
        });

        $("#btnSend").click(function () {
            sendMessage();
        });

        $("#txtMessage").keydown(function (e) {
            if (e.keyCode === 13 && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
    });

    function createNewChat() {
        currentSessionId = 0;
        $(".chat-item").removeClass("active");
        $("#txtMessage").val("");
        $("#chatBox").html(
            "<div class='msg-row ai'><div class='msg-bubble'>New chat started. Ask your question.</div></div>"
        );
    }

    function loadChatList() {
        $.ajax({
            url: "/AiAgent/GetChatSessions",
            type: "GET",
            success: function (data) {
                $("#chatList").html("");

                if (!data || data.length === 0) {
                    $("#chatList").append("<div style='color:#777;margin-top:8px;'>No previous chat</div>");
                    return;
                }

                $.each(data, function (i, item) {
                    $("#chatList").append(
                        "<div class='chat-item' id='chatItem_" + item.id + "' onclick='loadChat(" + item.id + ")'>" +
                        escapeHtml(item.title) +
                        "</div>"
                    );
                });
            }
        });
    }

    function loadChat(sessionId) {
        currentSessionId = sessionId;
        $(".chat-item").removeClass("active");
        $("#chatItem_" + sessionId).addClass("active");
        $("#chatBox").html("");

        $.ajax({
            url: "/AiAgent/GetChatMessages",
            type: "GET",
            data: { sessionId: sessionId },
            success: function (data) {
                $.each(data, function (i, msg) {
                    appendUserMessage(msg.userMessage);
                    appendAiMessage(msg.aiReply, false);
                });

                scrollBottom();
            }
        });
    }

    function sendMessage() {
        var msg = $("#txtMessage").val();
        var mode = $("#aiMode").val();

        if (!msg || msg.trim() === "") {
            alert("Please write a message.");
            return;
        }

        appendUserMessage(msg);
        $("#txtMessage").val("");
        $("#btnSend").prop("disabled", true).text("Sending...");

        var loadingId = addLoading();

        $.ajax({
            url: "/AiAgent/SendMessage",
            type: "POST",
            data: {
                sessionId: currentSessionId,
                mode: mode,
                message: msg
            },
            success: function (res) {
                $("#" + loadingId).remove();

                if (res.success) {
                    currentSessionId = res.sessionId;
                    appendAiMessage(res.reply, res.isHtml);
                    loadChatList();
                } else {
                    appendError(res.message);
                }
            },
            error: function (xhr) {
                $("#" + loadingId).remove();
                appendError(xhr.responseText);
            },
            complete: function () {
                $("#btnSend").prop("disabled", false).text("Send");
                $("#txtMessage").focus();
            }
        });
    }

    function appendUserMessage(text) {
        $("#chatBox").append(
            "<div class='msg-row user'><div class='msg-bubble'>" +
            escapeHtml(text) +
            "</div></div>"
        );
        scrollBottom();
    }

    function appendAiMessage(text, isHtml) {
        if (isHtml) {
            $("#chatBox").append(
                "<div class='msg-row ai'><div class='msg-bubble'>" +
                text +
                "</div></div>"
            );
        } else {
            $("#chatBox").append(
                "<div class='msg-row ai'><div class='msg-bubble'>" +
                escapeHtml(text) +
                "</div></div>"
            );
        }
        scrollBottom();
    }

    function addLoading() {
        var id = "loading_" + new Date().getTime();
        $("#chatBox").append(
            "<div class='msg-row ai' id='" + id + "'><div class='msg-bubble loading-text'>AI is thinking...</div></div>"
        );
        scrollBottom();
        return id;
    }

    function appendError(text) {
        $("#chatBox").append(
            "<div class='msg-row ai'><div class='msg-bubble' style='color:red;'>" +
            escapeHtml(text) +
            "</div></div>"
        );
        scrollBottom();
    }

    function scrollBottom() {
        $("#chatBox").scrollTop($("#chatBox")[0].scrollHeight);
    }

    function escapeHtml(text) {
        if (text == null) return "";
        return $("<div/>").text(text).html();
    }
</script>