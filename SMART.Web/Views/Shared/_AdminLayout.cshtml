<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SMART APP</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body {
            padding-top: 0;
            background-color: #f5f6fa;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 250px;
            background: #1f2d3d;
            color: #fff;
            flex-shrink: 0;
        }

            .admin-sidebar .sidebar-header {
                padding: 20px;
                font-size: 24px;
                font-weight: bold;
                border-bottom: 1px solid #2f4050;
            }

            .admin-sidebar ul {
                list-style: none;
                padding-left: 0;
                margin: 0;
            }

                .admin-sidebar ul li a {
                    display: block;
                    padding: 14px 20px;
                    color: #d1d5db;
                    text-decoration: none;
                    border-bottom: 1px solid #2f4050;
                }

                    .admin-sidebar ul li a:hover,
                    .admin-sidebar ul li.active > a {
                        background: #334155;
                        color: #fff;
                        text-decoration: none;
                    }

        .submenu {
            padding-left: 15px;
            background: #243447;
        }

        .admin-content {
            flex: 1;
            padding: 0;
        }

        .admin-header {
            background: #fff;
            border-bottom: 1px solid #ddd;
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .admin-header h2 {
                margin: 0;
                font-size: 32px;
            }

        .admin-main {
            padding: 20px 30px;
        }

        .admin-user {
            font-size: 18px;
            color: #555;
        }

        .body-content {
            width: 100%;
            padding-left: 0;
            padding-right: 0;
        }
    </style>
</head>
<body>
    <div class="admin-wrapper">
        <nav class="admin-sidebar">
            <div class="sidebar-header">Admin Panel</div>
            <ul>
                <li class="@(ViewBag.ActiveMenu == "Dashboard" ? "active" : "")">
                    <a href="@Url.Action("Index", "Home")">Dashboard</a>
                </li>
                <li>
                    <a href="/AiAgent">
                        <i class="fa fa-robot"></i>
                        <span>AI Agent</span>
                    </a>
                </li>

                <li class="@((ViewBag.ActiveMenu == "Complain" || ViewBag.ActiveMenu == "ComplainList" || ViewBag.ActiveMenu == "EmployeeComplainReview" || ViewBag.ActiveMenu == "MiddleManComplainList") ? "active" : "")">
                    <a href="javascript:void(0);">Complain</a>
                    <ul class="submenu">
                        <li class="@(ViewBag.ActiveMenu == "ComplainList" ? "active" : "")">
                            <a href="@Url.Action("Index", "EmployeeComplain")">Complain List</a>
                        </li>
                        <li class="@(ViewBag.ActiveMenu == "EmployeeComplainReview" ? "active" : "")">
                            <a href="@Url.Action("Review", "EmployeeComplain")">Employee Complain Review</a>
                        </li>
                        <li class="@(ViewBag.ActiveMenu == "MiddleManComplainList" ? "active" : "")">
                            <a href="@Url.Action("MiddleManList", "EmployeeComplain")">Complain Viewer</a>
                        </li>
                    </ul>
                </li>

                <li>
                    <a href="@Url.Action("Index", "Employee")">Employees</a>
                </li>

                <li>
                    <a href="@Url.Action("Index", "Home")">Back to Main Site</a>
                </li>
            </ul>
        </nav>

        <div class="admin-content">
            <header class="admin-header">
                <h2>@ViewBag.Title</h2>
                <div class="admin-user">
                    @if (User != null && User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @:Administrator
                    }
                </div>
            </header>

            <main class="admin-main">
                @RenderBody()
            </main>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>